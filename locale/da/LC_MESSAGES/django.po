msgstr "opret en forespørgsel, så nogen kan sende dig en whisper."

msgid ""
"You'll get two links: a <strong>submit link</strong> to share with the "
"sender, and a <strong>view link</strong> for you to retrieve the whisper "
"once it's been submitted."
msgstr ""
"Du får to links: et <strong>indsend-link</strong> til at dele med afsenderen "
"og et <strong>visningslink</strong> til at hente whisperen, når den er "
"blevet indsendt."

msgid "Expires after"
msgstr "Udløber efter"

msgid "5 Minutes"
msgstr "5 minutter"

msgid "1 Hour"
msgstr "1 time"

msgid "1 Day"
msgstr "1 dag"

msgid "1 Week"
msgstr "1 uge"

msgid "1 Month"
msgstr "1 måned"

msgid "Destroy after"
msgstr "Slet efter"

msgid ""
"The whisper is permanently destroyed after this many successful reveals. "
"Helps detect link leaks: an unexpected destruction means it was viewed more "
"times than you expected."
msgstr ""
"Whisperen slettes permanent efter dette antal vellykkede visninger. Hjælper "
"med at opdage lækkede links: en uventet sletning betyder, at den er blevet "
"vist flere gange, end du forventede."

msgid "1 view (burn 🔥)"
msgstr "1 visning (slet efter læsning 🔥)"

msgid "3 views"
msgstr "3 visninger"

msgid "5 views"
msgstr "5 visninger"

msgid "10 views"
msgstr "10 visninger"

msgid "Custom…"
msgstr "Tilpasset…"

msgid "Unlimited (time-based only)"
msgstr "Ubegrænset (kun tidsbaseret)"

msgid "Number of views (1–100)"
msgstr "Antal visninger (1–100)"

